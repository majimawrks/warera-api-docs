{
  "endpoint": "article.getArticleLiteById",
  "namespace": "article",
  "method": "getArticleLiteById",
  "auth": "none",
  "description": "Returns a lightweight article object by ID, including internal vote/like data.",
  "input": {
    "articleId": {
      "type": "string",
      "required": true,
      "description": "Article ID."
    }
  },
  "output": {
    "description": "See exampleResult for full structure.",
    "fields": {
      "_id": "string",
      "title": "string",
      "stats": "object",
      "stats.likes": "number",
      "stats.dislikes": "number",
      "stats.score": "number",
      "stats.views": "number",
      "stats.comments": "number",
      "stats.subs": "number",
      "stats.tips": "number",
      "stats.gemTips": "number"
    }
  },
  "notes": "Lighter payload than getArticleById but exposes internal fields.",
  "exampleRequest": {
    "articleId": "<articleId>"
  },
  "exampleResult": {
    "_id": "<articleId>",
    "title": "TITLE",
    "stats": {
      "likes": 0,
      "dislikes": 1,
      "score": -1,
      "views": 5,
      "comments": 0,
      "subs": 0,
      "tips": 0,
      "gemTips": 0
    }
  }
}