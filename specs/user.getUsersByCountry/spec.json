{
  "endpoint": "user.getUsersByCountry",
  "namespace": "user",
  "method": "getUsersByCountry",
  "auth": "optional",
  "description": "Returns a paginated list of users in a given country.",
  "input": {
    "countryId": {
      "type": "string",
      "required": true,
      "description": "Country ID."
    },
    "limit": {
      "type": "number",
      "required": false,
      "description": "Max results."
    },
    "cursor": {
      "type": "string",
      "required": false,
      "description": "Pagination cursor."
    }
  },
  "output": {
    "description": "See exampleResult for full structure.",
    "fields": {
      "items": "array of objects",
      "items[]._id": "string",
      "items[].createdAt": "string",
      "nextCursor": "string"
    }
  },
  "notes": "Returns `items` array and `nextCursor` for pagination.",
  "exampleRequest": {
    "countryId": "<countryId>",
    "limit": 2
  },
  "exampleResult": {
    "items": [
      {
        "_id": "<userId>",
        "createdAt": "<isoTimestamp>"
      },
      {
        "_id": "<userId>",
        "createdAt": "<isoTimestamp>"
      }
    ],
    "nextCursor": "NEXTCURSOR"
  }
}