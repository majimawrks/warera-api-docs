{
  "endpoint": "battleRanking.getRanking",
  "namespace": "battleRanking",
  "method": "getRanking",
  "auth": "optional",
  "description": "Returns rankings within a specific battle, grouped by entity type and side.",
  "input": {
    "battleId": {
      "type": "string",
      "required": true,
      "description": "Battle ID."
    },
    "type": {
      "type": "string",
      "required": true,
      "enum": [
        "user",
        "country",
        "mu"
      ],
      "description": "Entity type to rank within the battle."
    },
    "side": {
      "type": "string",
      "required": true,
      "enum": [
        "attacker",
        "defender",
        "merged"
      ],
      "description": "Which side to return. Use 'merged' for combined rankings."
    },
    "dataType": {
      "type": "string",
      "required": false,
      "enum": [
        "damage",
        "points"
      ],
      "description": "Metric to rank by. Default: damage."
    }
  },
  "output": {
    "description": "See exampleResult for full structure.",
    "fields": {
      "rankings": "array of objects",
      "rankings[].user": "string",
      "rankings[].value": "number",
      "rankings[].rank": "number",
      "rankings[]._id": "string"
    }
  },
  "notes": "All three of battleId, type, and side are required. Previous spec was incorrect — type and side were missing.",
  "exampleRequest": {
    "battleId": "<battleId>",
    "type": "user",
    "side": "merged",
    "dataType": "damage"
  },
  "exampleResult": {
    "rankings": [
      {
        "user": "<user>",
        "value": 76476,
        "rank": 1,
        "_id": "<rankingId>"
      },
      {
        "user": "<user>",
        "value": 46614,
        "rank": 2,
        "_id": "<rankingId>"
      }
    ]
  }
}