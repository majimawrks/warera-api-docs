{
  "endpoint": "referral.getUserReferrals",
  "namespace": "referral",
  "method": "getUserReferrals",
  "auth": "required",
  "description": "Returns a user's complete referral list (non-paginated).",
  "input": {
    "userId": {
      "type": "string",
      "required": true,
      "description": "User ID."
    }
  },
  "output": {
    "description": "See exampleResult for full structure.",
    "fields": {
      "items": "array of objects",
      "items[].referredUserId": "string",
      "items[].createdAt": "string",
      "nextCursor": "string | null"
    }
  },
  "notes": "Requires JWT cookie auth (Cookie: jwt=...). API key is not accepted. Returns an array of referred user objects.",
  "exampleRequest": {
    "userId": "<userId>"
  },
  "exampleResult": {
    "items": [
      {
        "referredUserId": "<referredUserId>",
        "createdAt": "<isoTimestamp>"
      }
    ],
    "nextCursor": null
  }
}