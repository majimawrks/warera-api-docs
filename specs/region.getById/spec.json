      "biome": "string",
      "climate": "string",
      "__v": "number",
      "resistance": "number",
      "activeUpgradeLevels": "object",
      "activeUpgradeLevels.bunker": "number",
      "resistanceMax": "number",
      "lastResistanceContributionAt": "string",
      "lastRevoltEndedAt": "string",
      "lastBattleEndedAt": "string"
    }
  },
