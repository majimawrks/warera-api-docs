{
  "endpoint": "region.getById",
  "namespace": "region",
  "method": "getById",
  "auth": "none",
  "description": "Returns full region data by region ID.",
  "input": {
    "regionId": {
      "type": "string",
      "required": true,
      "description": "Region ID."
    }
  },
  "output": {
    "description": "See exampleResult for full structure.",
    "fields": {
      "stats": "object",
      "stats.investedMoney": "number",
      "dates": "object",
      "dates.lastOwnershipChangeAt": "string",
