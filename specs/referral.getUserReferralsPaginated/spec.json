{
  "endpoint": "referral.getUserReferralsPaginated",
  "namespace": "referral",
  "method": "getUserReferralsPaginated",
  "auth": "required",
  "description": "Returns a paginated user referral list.",
  "input": {
    "userId": {
      "type": "string",
      "required": true,
      "description": "User ID."
    },
    "limit": {
      "type": "number",
      "required": false,
      "description": "Max results."
    }
  },
  "output": {
    "description": "See exampleResult for full structure.",
    "fields": {
      "items": "array of objects",
      "items[].referredUserId": "string",
      "items[].createdAt": "string",
      "nextCursor": "string | null"
    }
  },
  "notes": "Requires JWT cookie auth (Cookie: jwt=...). API key is not accepted. No cursor param available.",
  "exampleRequest": {
    "userId": "<userId>"
  },
  "exampleResult": {
    "items": [
      {
        "referredUserId": "<referredUserId>",
        "createdAt": "<isoTimestamp>"
      }
    ],
    "nextCursor": null
  }
}